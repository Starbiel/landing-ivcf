---
import Box from './Box.astro';

type CarouselImageSource = string | { src: string };

interface CarouselItem {
	src: CarouselImageSource;
	alt: string;
	title?: string;
	caption?: string;
}

interface Props {
	items: CarouselItem[];
	class?: string;
	ariaLabel?: string;
	aspectRatio?: 'square' | 'video' | 'wide' | 'portrait';
	autoPlay?: boolean;
	interval?: number;
	loop?: boolean;
	pauseOnHover?: boolean;
	showArrows?: boolean;
	showDots?: boolean;
}

const {
	items = [],
	class: className,
	ariaLabel = 'Carrossel de imagens',
	aspectRatio = 'video',
	autoPlay = true,
	interval = 4500,
	loop = true,
	pauseOnHover = true,
	showArrows = true,
	showDots = true,
} = Astro.props as Props;

const slides = items.filter(Boolean);
const hasManySlides = slides.length > 1;

const aspectClasses = {
	square: 'aspect-square',
	video: 'aspect-video',
	wide: 'aspect-[16/9]',
	portrait: 'aspect-[4/5]',
};

const resolveSrc = (source: CarouselImageSource) => (typeof source === 'string' ? source : source.src);
---

<Box
	tone="glass"
	border
	radius="2xl"
	elevated
	class={`overflow-hidden ${className ?? ''}`.trim()}
>
	<div
		data-carousel
		role="region"
		aria-roledescription="carousel"
		aria-label={ariaLabel}
		data-autoplay={autoPlay && hasManySlides ? 'true' : 'false'}
		data-interval={interval}
		data-loop={loop && hasManySlides ? 'true' : 'false'}
		data-pause-on-hover={pauseOnHover && hasManySlides ? 'true' : 'false'}
		data-total={slides.length}
		class="space-y-4"
	>
		<div class={`relative overflow-hidden ${aspectClasses[aspectRatio]}`} tabindex="0">
			<div
				data-carousel-track
				class="flex h-full w-full will-change-transform transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]"
				style={hasManySlides ? 'transform: translateX(-100%);' : 'transform: translateX(0);'}
			>
				{hasManySlides && (
					<div data-carousel-slide class="relative h-full min-w-full shrink-0">
							<img src={resolveSrc(slides.at(-1)?.src ?? '')} alt={slides.at(-1)?.alt ?? ''} class="h-full w-full object-cover" loading="lazy" decoding="async" draggable="false" />
					</div>
				)}

				{slides.map((item) => (
					<div data-carousel-slide class="relative h-full min-w-full shrink-0">
							<img src={resolveSrc(item.src)} alt={item.alt} class="h-full w-full object-cover" loading="lazy" decoding="async" draggable="false" />
						{(item.title || item.caption) && (
							<div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-deep-blue/85 via-deep-blue/35 to-transparent p-5 text-text-pure-white">
								{item.caption && <p class="text-xs uppercase tracking-[0.24em] text-accent-cyan">{item.caption}</p>}
								{item.title && <p class="mt-1 text-lg font-semibold">{item.title}</p>}
							</div>
						)}
					</div>
				))}

				{hasManySlides && (
					<div data-carousel-slide class="relative h-full min-w-full shrink-0">
							<img src={resolveSrc(slides[0].src)} alt={slides[0].alt} class="h-full w-full object-cover" loading="lazy" decoding="async" draggable="false" />
					</div>
				)}
			</div>

			{showArrows && hasManySlides && (
				<>
					<button
						type="button"
						data-carousel-prev
						aria-label="Imagem anterior"
						class="absolute left-4 top-1/2 -translate-y-1/2 rounded-full border border-white/10 bg-deep-blue/70 p-3 text-text-pure-white backdrop-blur-md transition hover:border-accent-cyan/50 hover:bg-deep-blue/85"
					>
						<span class="block text-lg leading-none">‹</span>
					</button>
					<button
						type="button"
						data-carousel-next
						aria-label="Próxima imagem"
						class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full border border-white/10 bg-deep-blue/70 p-3 text-text-pure-white backdrop-blur-md transition hover:border-accent-cyan/50 hover:bg-deep-blue/85"
					>
						<span class="block text-lg leading-none">›</span>
					</button>
				</>
			)}
		</div>

		{showDots && hasManySlides && (
			<div class="flex items-center justify-center gap-2 pb-1">
				{slides.map((item, index) => (
					<button
						type="button"
						data-carousel-dot={index}
						aria-label={`Ir para a imagem ${index + 1}`}
						aria-current={index === 0 ? 'true' : 'false'}
						class={`h-2.5 w-2.5 rounded-full transition ${index === 0 ? 'bg-accent-cyan' : 'bg-white/30 hover:bg-white/55'}`}
					></button>
				))}
			</div>
		)}
	</div>
</Box>

<script is:inline type="module">
	const carousels = Array.from(document.querySelectorAll('[data-carousel]'));

	for (const root of carousels) {
		const track = root.querySelector('[data-carousel-track]');
		const prevButton = root.querySelector('[data-carousel-prev]');
		const nextButton = root.querySelector('[data-carousel-next]');
		const dots = Array.from(root.querySelectorAll('[data-carousel-dot]'));
		const total = Number(root.getAttribute('data-total') ?? '0');
		const autoplayEnabled = root.getAttribute('data-autoplay') === 'true';
		const loopEnabled = root.getAttribute('data-loop') === 'true';
		const pauseOnHover = root.getAttribute('data-pause-on-hover') === 'true';
		const intervalMs = Number(root.getAttribute('data-interval') ?? '4500');
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!track || total < 2) {
			continue;
		}

		let index = 1;
		let timerId = null;

		const normalizedIndex = () => (index - 1 + total) % total;

		const syncDots = () => {
			const activeIndex = normalizedIndex();

			dots.forEach((dot, dotIndex) => {
				const active = dotIndex === activeIndex;
				dot.setAttribute('aria-current', active ? 'true' : 'false');
				dot.classList.toggle('bg-accent-cyan', active);
				dot.classList.toggle('bg-white/30', !active);
				dot.classList.toggle('hover:bg-white/55', !active);
			});
		};

		const render = (animate = true) => {
			track.style.transition = animate ? '' : 'none';
			track.style.transform = `translateX(-${index * 100}%)`;
			syncDots();
		};

		const goTo = (nextIndex, animate = true) => {
			index = nextIndex;
			render(animate);
		};

		const next = () => goTo(index + 1);
		const prev = () => goTo(index - 1);

		const stopAutoplay = () => {
			if (timerId !== null) {
				window.clearInterval(timerId);
				timerId = null;
			}
		};

		const startAutoplay = () => {
			if (!autoplayEnabled || reduceMotion || timerId !== null) {
				return;
			}

			timerId = window.setInterval(() => {
				next();
			}, intervalMs);
		};

		track.addEventListener('transitionend', () => {
			if (!loopEnabled) {
				return;
			}

			if (index === 0) {
				goTo(total, false);
			}

			if (index === total + 1) {
				goTo(1, false);
			}
		});

		prevButton?.addEventListener('click', () => {
			stopAutoplay();
			prev();
			startAutoplay();
		});

		nextButton?.addEventListener('click', () => {
			stopAutoplay();
			next();
			startAutoplay();
		});

		dots.forEach((dot, dotIndex) => {
			dot.addEventListener('click', () => {
				stopAutoplay();
				goTo(dotIndex + 1);
				startAutoplay();
			});
		});

		root.addEventListener('keydown', (event) => {
			if (event.key === 'ArrowLeft') {
				event.preventDefault();
				stopAutoplay();
				prev();
				startAutoplay();
			}

			if (event.key === 'ArrowRight') {
				event.preventDefault();
				stopAutoplay();
				next();
				startAutoplay();
			}
		});

		if (pauseOnHover) {
			root.addEventListener('mouseenter', stopAutoplay);
			root.addEventListener('mouseleave', startAutoplay);
		}

		document.addEventListener('visibilitychange', () => {
			if (document.hidden) {
				stopAutoplay();
			} else {
				startAutoplay();
			}
		});

		render(false);
		startAutoplay();
	}
</script>
