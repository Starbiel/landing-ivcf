---
import Box from './Box.astro';

type CarouselImageSource = string | { src: string };

interface CarouselItem {
	src: CarouselImageSource;
	alt: string;
	title?: string;
	caption?: string;
}

interface Props {
	items: CarouselItem[];
	class?: string;
	ariaLabel?: string;
	aspectRatio?: 'square' | 'video' | 'wide' | 'portrait';
	speed?: number;        // seconds to cross the full strip; default 30
	slideWidth?: string;   // width of each slide; default '33%' (3 visible at once)
	gap?: number;          // gap between slides in px; default 16
	pauseOnHover?: boolean;
	direction?: 'left' | 'right';
}

const {
	items = [],
	class: className,
	ariaLabel = 'Faixa de imagens',
	aspectRatio = 'video',
	speed = 30,
	slideWidth = '33%',
	gap = 16,
	pauseOnHover = true,
	direction = 'left',
} = Astro.props as Props;

const slides = items.filter(Boolean);

// Duplicate slides enough times to always fill the track seamlessly.
// We need at least ~3 sets so the animation never shows a gap.
const minSets = Math.max(3, Math.ceil(6 / (slides.length || 1)));
const repeated = Array.from({ length: minSets }, () => slides).flat();

const aspectClasses: Record<string, string> = {
	square: 'aspect-square',
	video: 'aspect-video',
	wide: 'aspect-[16/9]',
	portrait: 'aspect-[4/5]',
};

const resolveSrc = (source: CarouselImageSource) =>
	typeof source === 'string' ? source : source.src;

// The keyframe translates by exactly one full "original set" width.
// Because we duplicate the set, the loop is invisible.
// We pass the slide count so JS can set the correct CSS variable.
---

<Box
	tone="glass"
	border
	radius="2xl"
	elevated
	class={`overflow-hidden ${className ?? ''}`.trim()}
>
	<div
		role="region"
		aria-roledescription="marquee"
		aria-label={ariaLabel}
		class="marquee-root relative overflow-hidden"
		style={`--slide-width: ${slideWidth}; --gap: ${gap}px; --speed: ${speed}s; --sets: ${minSets};`}
		data-pause-on-hover={pauseOnHover ? 'true' : 'false'}
		data-direction={direction}
		data-count={slides.length}
	>
		<!-- fade edges -->
		<div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-deep-blue/70 to-transparent" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-deep-blue/70 to-transparent" aria-hidden="true"></div>

		<div class="marquee-track flex" aria-hidden="true">
			{repeated.map((item) => (
				<div
					class={`marquee-slide shrink-0 ${aspectClasses[aspectRatio]} overflow-hidden rounded-xl`}
					style={`width: var(--slide-width); margin-right: var(--gap);`}
				>
					<img
						src={resolveSrc(item.src)}
						alt={item.alt}
						class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
						loading="lazy"
						decoding="async"
						draggable="false"
					/>
					{(item.title || item.caption) && (
						<div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-deep-blue/85 via-deep-blue/35 to-transparent p-4 text-white">
							{item.caption && (
								<p class="text-xs uppercase tracking-[0.24em] text-accent-cyan">{item.caption}</p>
							)}
							{item.title && (
								<p class="mt-0.5 text-sm font-semibold">{item.title}</p>
							)}
						</div>
					)}
				</div>
			))}
		</div>
	</div>
</Box>

<style>
	.marquee-track {
		/* The animation moves the strip by (100% / sets), i.e. one original set width */
		animation: marquee-scroll var(--speed, 30s) linear infinite;
		will-change: transform;
	}

	[data-direction='right'] .marquee-track {
		animation-direction: reverse;
	}

	@keyframes marquee-scroll {
		from { transform: translateX(0); }
		/* translate by exactly one set = 100% / minSets */
		to   { transform: translateX(calc(-100% / var(--sets, 3))); }
	}

	@media (prefers-reduced-motion: reduce) {
		.marquee-track {
			animation: none;
		}
	}
</style>

<script is:inline type="module">
	for (const root of document.querySelectorAll('[data-pause-on-hover]')) {
		if (root.getAttribute('data-pause-on-hover') !== 'true') continue;
		const track = root.querySelector('.marquee-track');
		if (!track) continue;
		root.addEventListener('mouseenter', () => {
			track.style.animationPlayState = 'paused';
		});
		root.addEventListener('mouseleave', () => {
			track.style.animationPlayState = 'running';
		});
	}
</script>