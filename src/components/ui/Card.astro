---
import Box from './Box.astro';

type CardAs = 'div' | 'article' | 'section' | 'li';

interface Props {
	as?: CardAs;
	class?: string;
	eyebrow?: string;
	title?: string;
	description?: string;
	interactive?: boolean;
}

const {
	as = 'article',
	class: className,
	eyebrow,
	title,
	description,
	interactive = false,
} = Astro.props as Props;
---

<Box
	as={as}
	tone="surface"
	radius="2xl"
	elevated
	class={`relative overflow-hidden ${interactive ? 'transform-gpu transition duration-300 hover:-translate-y-1 hover:border-accent-cyan/50 hover:shadow-[0_28px_90px_rgba(74,159,255,0.18)]' : ''} ${className ?? ''}`.trim()}
>
	<div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/70 to-transparent"></div>

	{(eyebrow || title || description) && (
		<header class="space-y-3">
			{eyebrow && <p class="text-xs font-semibold uppercase tracking-[0.24em] text-accent-cyan">{eyebrow}</p>}
			{title && <h3 class="text-2xl font-semibold tracking-[-0.03em] text-text-pure-white">{title}</h3>}
			{description && <p class="text-sm leading-6 text-text-off-white/80">{description}</p>}
		</header>
	)}

	<div class={title || description || eyebrow ? 'mt-6' : ''}>
		<slot />
	</div>
</Box>
