---
import Box from "../ui/Box.astro";
import Card from "../ui/Card.astro";
import Typography from "../ui/Typography.astro";
---

<Box as="section" id="beneficios" class="flex-col justify-center items-center mx-auto w-full px-6 py-16 lg:px-10 lg:py-20">
    <Box class="max-w-7xl mx-auto">
        <div class="mb-8 max-w-2xl space-y-3">
            <Typography variant="caption">Benefícios</Typography>
            <Typography as="h2" variant="h2">Por que migrar para o IVCF-20 Digital?</Typography>
            <Typography variant="body" tone="muted">
				Eficiência que se traduz em melhor cuidado para o idoso.
			</Typography>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
            <Card title="Mais tempo" description="Redução no tempo de preenchimento e processamento dos dados em comparação ao papel." />
            <Card title="Mais Precisão" description="Erro zero nos cálculos de escore e classificação automática do grau de fragilidade." />
            <Card title="Mais Dados" description="Identificação visual imediata de pontos críticos através dos gráficos automáticos." />
        </div>
    </Box>
</Box>
