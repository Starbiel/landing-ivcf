---
import Carrossel from "../ui/Carrossel.astro";
import Typography from "../ui/Typography.astro";

import Heatmap from "../../assets/images/heatmap_chart.jpg";
import Risk from "../../assets/images/risk_chart.jpg";
import Dots from "../../assets/images/dots_chart.jpg";
import Questions from "../../assets/images/questions_bar.jpg";
import Pyramid from "../../assets/images/pyramid_chart.jpg";

const images = [
	{ src: Heatmap, alt: "Heatmap Chart" },
	{ src: Risk, alt: "Risk Chart" },
	{ src: Dots, alt: "Dots Chart" },
	{ src: Questions, alt: "Questions Bar Chart" },
	{ src: Pyramid, alt: "Pyramid Chart" },
];
---

<section class="mx-auto w-full max-w-7xl px-6 py-20 lg:px-10 lg:py-28">
	<div class="grid gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
		<div class="max-w-3xl space-y-6">
			<Typography variant="eyebrow">Sistema IVCF</Typography>
			<Typography as="h1" variant="display">
				Projetos que conectam tecnologia, saúde e bem-estar em uma única experiência.
			</Typography>
			<Typography variant="body-lg" tone="muted">
				Uma apresentação visual forte, circular e contínua para destacar os principais gráficos do sistema
				sem quebrar a leitura da landing.
			</Typography>
		</div>

		
	</div><Carrossel items={images} aspectRatio="wide" />
</section>
