---
import Carrossel from "../ui/Carrossel.astro";
import Typography from "../ui/Typography.astro";
import Box from "../ui/Box.astro";

import Heatmap from "../../assets/images/heatmap_chart.jpg";
import Risk from "../../assets/images/risk_chart.jpg";
import Dots from "../../assets/images/dots_chart.jpg";
import Questions from "../../assets/images/questions_bar.jpg";
import Pyramid from "../../assets/images/pyramid_chart.jpg";

const images = [
	{ src: Heatmap, alt: "Heatmap Chart" },
	{ src: Risk, alt: "Risk Chart" },
	{ src: Dots, alt: "Dots Chart" },
	{ src: Questions, alt: "Questions Bar Chart" },
	{ src: Pyramid, alt: "Pyramid Chart" },
];
---

<Box as="section" class="flex justify-center mx-auto w-full px-6 py-10 lg:px-10 lg:py-28">
    <Box class="max-w-7xl" >
        <div class="gap-10 lg:items-center">
            <div class="space-y-6 mb-10">

                <Box class="flex flex-col items-center text-center mx-auto w-full max-w-3xl gap-6">
                    <Typography as="h1" variant="display">
                        IVCF-20 Digital
                    </Typography>
                    <Typography variant="body-lg" tone="muted">
                        Tecnologia avançada para o diagnóstico da fragilidade. 
                        Visualize indicadores clínicos complexos de forma clara, 
                        contínua e integrada ao fluxo de trabalho da sua clinica ou laboratório.
                    </Typography>
                </Box>
            </div>
        </div>
        <Carrossel items={images} aspectRatio="wide" />

        <Box class="flex flex-col items-center text-center mx-auto w-full max-w-3xl gap-6 mt-10">
            <Typography variant="body-lg" tone="muted">
                O IVCF-20 Digital é a evolução natural do protocolo tradicional, 
                trazendo agilidade, precisão e uma experiência de usuário otimizada 
                para profissionais de saúde que buscam excelência no cuidado geriátrico.
            </Typography>

            <div class="flex items-center gap-3 w-full">
				<a href="http://ivcf.com.br/login" target="_blank" rel="noopener noreferrer" class="w-full rounded-md bg-accent-cyan px-4 py-4 text-sm font-semibold text-white hover:opacity-90">Acessar o sistema</a>
			</div>
        </Box>
    </Box>
</Box>
